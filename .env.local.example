STRIPE_PRICE_ID=price_...

# --- Mapbox ---
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
